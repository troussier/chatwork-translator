{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "default_locale": "ja",
  "version": "0.2",

  "permissions": ["storage"],

  "options_page": "options/options.html",

  "content_scripts": [
    {
      "matches": ["https://www.chatwork.com/*"],
      "js": [
        "cache.js",
        "ui.js",
        "dom.js",
        "translator.js",
        "content.js"
      ]
    }
  ]
}